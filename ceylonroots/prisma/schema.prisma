// This is the CeylonRoots Prisma schema
// Mirrors the Java Spring Boot entity models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum ComponentType {
  ACCOMMODATION
  ACTIVITY
  DESTINATION
  TRANSPORT
}

enum Difficulty {
  EASY
  MODERATE
  CHALLENGING
}

enum TransportMode {
  CAR
  TRAIN
  BUS
  PLANE
  BOAT
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACKS
}

enum GalleryItemType {
  IMAGE
  VIDEO
}

// ==================== TRAVEL COMPONENT (Single Table Inheritance) ====================

model TravelComponent {
  id            Int           @id @default(autoincrement())
  componentType ComponentType @map("component_type")
  name          String
  description   String?       @db.Text
  location      String?
  imageUrl      String?       @map("image_url")
  price         Decimal?      @db.Decimal(10, 2)
  lat           Float?
  lng           Float?
  duration      Int?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Component-specific tags
  tags ComponentTag[]

  // Accommodation-specific
  rating    Float?
  amenities Amenity[]

  // Activity-specific
  difficulty      Difficulty?
  activityGallery ActivityGallery[]

  // Transport-specific
  mode              TransportMode?
  departureLocation String?         @map("departure_location")
  arrivalLocation   String?         @map("arrival_location")
  departureLat      Float?          @map("departure_lat")
  departureLng      Float?          @map("departure_lng")
  arrivalLat        Float?          @map("arrival_lat")
  arrivalLng        Float?          @map("arrival_lng")

  // Destination-specific
  destinationAttractions DestinationAttraction[]
  destinationGallery     DestinationGallery[]

  @@map("travel_component")
}

model ComponentTag {
  id          Int             @id @default(autoincrement())
  tag         String
  component   TravelComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  componentId Int             @map("component_id")

  @@map("component_tags")
}

model Amenity {
  id              Int             @id @default(autoincrement())
  amenity         String
  accommodation   TravelComponent @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  accommodationId Int             @map("accommodation_id")

  @@map("accommodation_amenities")
}

model DestinationAttraction {
  id            Int             @id @default(autoincrement())
  attraction    String
  destination   TravelComponent @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  destinationId Int             @map("destination_id")

  @@map("destination_attractions")
}

// ==================== GALLERY ====================

model GalleryItem {
  id           Int             @id @default(autoincrement())
  type         GalleryItemType
  url          String
  thumbnailUrl String?         @map("thumbnail_url")
  caption      String?
  location     String?
  description  String?         @db.Text
  featured     Boolean?        @default(false)
  dateAdded    DateTime?       @map("date_added") @db.Date
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  destinations DestinationGallery[]
  activities   ActivityGallery[]

  @@map("gallery_item")
}

model DestinationGallery {
  destination   TravelComponent @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  destinationId Int             @map("destination_id")
  gallery       GalleryItem     @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  galleryId     Int             @map("gallery_id")

  @@id([destinationId, galleryId])
  @@map("destination_gallery")
}

model ActivityGallery {
  activity   TravelComponent @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId Int             @map("activity_id")
  gallery    GalleryItem     @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  galleryId  Int             @map("gallery_id")

  @@id([activityId, galleryId])
  @@map("activity_gallery")
}

// ==================== TRAVEL PACKAGE ====================

model TravelPackage {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  durationDays Int?    @map("duration_days")
  price       Decimal? @db.Decimal(10, 2)
  rating      Float?
  reviewCount Int?     @map("review_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  destinations  PackageDestination[]
  highlights    PackageHighlight[]
  gallery       PackageGalleryItem[]
  includes      PackageInclude[]
  excludes      PackageExclude[]
  itineraryDays ItineraryDay[]
  reviews       Review[]
  bookings      Booking[]
  departures    PackageDeparture[]

  @@map("travel_package")
}

model PackageDestination {
  id          Int           @id @default(autoincrement())
  destination String
  package     TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId   Int           @map("package_id")

  @@map("package_destinations")
}

model PackageHighlight {
  id        Int           @id @default(autoincrement())
  highlight String
  package   TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId Int           @map("package_id")

  @@map("package_highlights")
}

model PackageGalleryItem {
  id        Int           @id @default(autoincrement())
  url       String
  package   TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId Int           @map("package_id")

  @@map("package_gallery")
}

model PackageInclude {
  id        Int           @id @default(autoincrement())
  item      String
  package   TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId Int           @map("package_id")

  @@map("package_includes")
}

model PackageExclude {
  id        Int           @id @default(autoincrement())
  item      String
  package   TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId Int           @map("package_id")

  @@map("package_excludes")
}

// ==================== ITINERARY DAY ====================

model ItineraryDay {
  id              Int           @id @default(autoincrement())
  dayNumber       Int           @map("day_number")
  title           String?
  mainTown        String?       @map("main_town")
  description     String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  travelPackage   TravelPackage @relation(fields: [travelPackageId], references: [id], onDelete: Cascade)
  travelPackageId Int           @map("travel_package_id")

  accommodation DayAccommodation[]
  meals         DayMeal[]
  activities    DayActivity[]

  @@map("itinerary_day")
}

model DayAccommodation {
  id    Int          @id @default(autoincrement())
  name  String
  day   ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  dayId Int          @map("day_id")

  @@map("day_accommodation")
}

model DayMeal {
  id    Int          @id @default(autoincrement())
  meal  MealType
  day   ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  dayId Int          @map("day_id")

  @@map("day_meal")
}

model DayActivity {
  id    Int          @id @default(autoincrement())
  name  String
  day   ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  dayId Int          @map("day_id")

  @@map("itinerary_day_activities")
}

// ==================== BLOG ====================

model BlogPost {
  id           Int      @id @default(autoincrement())
  title        String
  excerpt      String?  @db.Text
  content      String?  @db.Text
  imageUrl     String?  @map("image_url")
  postDate     DateTime? @map("post_date") @db.Date
  author       String?
  category     String?
  commentCount Int?     @default(0) @map("comment_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  comments     BlogComment[]
  relatedPosts RelatedPost[] @relation("PostToRelated")
  relatedTo    RelatedPost[] @relation("RelatedToPost")

  @@map("blog_post")
}

model BlogComment {
  id          Int       @id @default(autoincrement())
  author      String?
  avatarUrl   String?   @map("avatar_url")
  commentDate DateTime? @map("comment_date")
  text        String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  post        BlogPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      Int       @map("blog_post_id")

  @@map("blog_comment")
}

model RelatedPost {
  post      BlogPost @relation("PostToRelated", fields: [postId], references: [id], onDelete: Cascade)
  postId    Int      @map("post_id")
  related   BlogPost @relation("RelatedToPost", fields: [relatedId], references: [id], onDelete: Cascade)
  relatedId Int      @map("related_id")

  @@id([postId, relatedId])
  @@map("related_posts")
}

// ==================== DESTINATION DETAILS ====================

model DestinationDetails {
  id                  Int      @id @default(autoincrement())
  name                String
  description         String?  @db.Text
  region              String?
  topAttraction       String?  @map("top_attraction")
  bestTimeToVisit     String?  @map("best_time_to_visit")
  recommendedDuration String?  @map("recommended_duration")
  culturalTips        String?  @map("cultural_tips")
  image               String?
  latitude            Float?
  longitude           Float?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  attractions DestinationDetailAttraction[]

  @@map("destination_details")
}

model DestinationDetailAttraction {
  id        Int                @id @default(autoincrement())
  attraction String
  details   DestinationDetails @relation(fields: [detailsId], references: [id], onDelete: Cascade)
  detailsId Int                @map("details_id")

  @@map("destination_detail_attractions")
}

// ==================== TESTIMONIALS ====================

model Testimonial {
  id          Int      @id @default(autoincrement())
  name        String
  location    String
  image       String?
  rating      Int      @default(5)
  testimonial String   @db.Text
  tourType    String?  @map("tour_type")
  tourDate    String?  @map("tour_date")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("testimonial")
}

// ==================== GUIDES ====================

model Guide {
  id           Int      @id @default(autoincrement())
  name         String
  photo        String?
  bio          String   @db.Text
  expertise    String[] // e.g., ["Wildlife", "Cultural", "Photography"]
  languages    String[] // e.g., ["English", "Sinhala", "Tamil"]
  experience   Int      // years
  rating       Float    @default(5.0)
  reviewCount  Int      @default(0) @map("review_count")
  responseTime String?  @map("response_time") // e.g., "Within 2 hours"
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("guide")
}

// ==================== REVIEWS ====================

model Review {
  id              Int           @id @default(autoincrement())
  packageId       Int           @map("package_id")
  package         TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  authorName      String        @map("author_name")
  authorEmail     String        @map("author_email")
  rating          Float         // overall 1–5
  guideRating     Float?        @map("guide_rating")
  valueRating     Float?        @map("value_rating")
  itineraryRating Float?        @map("itinerary_rating")
  comment         String        @db.Text
  travelType      String?       @map("travel_type") // "Solo", "Couple", "Family", "Group"
  tripDate        String?       @map("trip_date")   // "January 2025"
  verified        Boolean       @default(false)
  helpful         Int           @default(0)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("review")
}

// ==================== AUTH (NextAuth / Auth.js v5) ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?   // bcrypt hashed — null for OAuth users
  role          String    @default("user") // "user" | "admin"
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  bookings  Booking[]

  @@map("user")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}

// ==================== BOOKINGS ====================

model Booking {
  id              String        @id @default(cuid())
  userId          String?       @map("user_id")
  user            User?         @relation(fields: [userId], references: [id])
  packageId       Int           @map("package_id")
  package         TravelPackage @relation(fields: [packageId], references: [id])
  firstName       String        @map("first_name")
  lastName        String        @map("last_name")
  email           String
  phone           String
  travelerCount   Int           @map("traveler_count")
  totalAmount     Float         @map("total_amount")
  status          String        @default("pending") // pending, confirmed, cancelled
  paymentMethod   String?       @map("payment_method")
  specialRequests String?       @map("special_requests") @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("booking")
}

// ==================== PACKAGE DEPARTURES ====================

model PackageDeparture {
  id            Int           @id @default(autoincrement())
  packageId     Int           @map("package_id")
  package       TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  departureDate DateTime      @map("departure_date") @db.Date
  maxSlots      Int           @map("max_slots")
  bookedSlots   Int           @default(0) @map("booked_slots")
  priceOverride Float?        @map("price_override")
  status        String        @default("available") // available, limited, full, cancelled
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("package_departure")
}
